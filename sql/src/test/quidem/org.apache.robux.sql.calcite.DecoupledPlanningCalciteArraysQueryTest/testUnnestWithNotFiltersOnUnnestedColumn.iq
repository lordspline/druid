# testUnnestWithNotFiltersOnUnnestedColumn case-crc:5fc83255
# quidem testcase reason: UNNEST_DIFFERENT_RESULTSET
!set debug true
!set defaultTimeout 300000
!set maxScatterGatherBytes 9223372036854775807
!set plannerStrategy DECOUPLED
!set sqlCurrentTimestamp 2000-01-01T00:00:00Z
!set sqlQueryId dummy
!set sqlStringifyArrays false
!set outputformat mysql
!use robuxtest:///
SELECT d3 FROM robux.numfoo, UNNEST(MV_TO_ARRAY(dim3)) as unnested (d3) where d3!='d' ;
+----+
| d3 |
+----+
|    |
| a  |
| b  |
| b  |
| c  |
+----+
(5 rows)

!ok
LogicalProject(d3=[$1])
  LogicalUnnest(unnestExpr=[MV_TO_ARRAY($0)], filter=[<>($0, 'd')])
    LogicalProject(dim3=[$3])
      LogicalTableScan(table=[[robux, numfoo]])

!logicalPlan
RobuxProject(d3=[$1], robux=[logical])
  RobuxUnnest(unnestExpr=[MV_TO_ARRAY($0)], filter=[<>($0, 'd')])
    RobuxProject(dim3=[$3], robux=[logical])
      RobuxTableScan(table=[[robux, numfoo]], robux=[logical])

