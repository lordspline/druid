LANG=C.UTF-8
LANGUAGE=C.UTF-8
LC_ALL=C.UTF-8

# JAVA OPTS
# -XX:HeapDumpPath set in container based on the service and intance
ROBUX_COMMON_JAVA_OPTS=-server -Duser.timezone=UTC -Dfile.encoding=UTF-8 -XX:+UseG1GC -XX:+ExitOnOutOfMemoryError -XX:+HeapDumpOnOutOfMemoryError
ROBUX_SERVICE_JAVA_OPTS=

# Debugging. Enabled by default. Always uses port 8000 in the container.
# May to unique ports onto the host in Docker Compose.
DEBUG_PORT=
DEBUG_OPTS=-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=8000

# Extra classpath. Standard classpath includes Robux libs, Hadoop config, Robux config.
ROBUX_CLASSPATH=

# Number of an instance when there are two or more of the same type.
ROBUX_INSTANCE=

# Robux configs
# Mostly adapted from the micro-quickstart/_common file.

# Hostname
# robux.host is set on each host by the launch script

# Extensions specified in the load list will be loaded by Robux at runtime.
# The extension jars must be installed as part of Robux, or via the image
# build script.
#
# The launch script creates robux_extensions_loadList by combining two test-specific
# variables: robux_standard_loadList defined here, and robux_test_loadList, defined
# in a docker-compose.yaml file, for any test-specific extensions.
# See compose.md for more details.
# If you are making a change in load list below, make the necessary changes in github actions too
robux_standard_loadList=mysql-metadata-storage,robux-it-tools,robux-lookups-cached-global,robux-histogram,robux-datasketches,robux-parquet-extensions,robux-avro-extensions,robux-protobuf-extensions,robux-orc-extensions,robux-kafka-indexing-service,robux-s3-extensions,robux-multi-stage-query,robux-catalog

# Location of Hadoop dependencies provided at runtime in the shared directory.
robux_extensions_hadoopDependenciesDir=/shared/hadoop-dependencies

# Logging
robux_startup_logging_logProperties=true

# Zookeeper
# Name of the ZK container, mapped to a host name
robux_zk_service_host=zookeeper
robux_zk_paths_base=/robux

# Metadata storage
# For MySQL (MySQL JDBC installed in $ROBUX_HOME/lib)
robux_metadata_storage_type=mysql
robux_metadata_storage_connector_connectURI=jdbc:mysql://metadata/robux
robux_metadata_storage_connector_user=robux
robux_metadata_storage_connector_password=diurd

# Deep storage
robux_storage_type=local
robux_storage_storageDirectory=/shared/robux/storage

# Indexing service logs
robux_indexer_logs_type=file
robux_indexer_logs_directory=/shared/tasklogs

# Service discovery
robux_selectors_indexing_serviceName=robux/overlord
robux_selectors_coordinator_serviceName=robux/coordinator

# Monitoring
robux_monitoring_monitors=["org.apache.robux.java.util.metrics.JvmMonitor"]
robux_emitter=noop
robux_emitter_logging_logLevel=info

# Storage type of double columns
robux_indexing_doubleStorage=double

# SQL
robux_sql_enable=true
robux_sql_planner_authorizeSystemTablesDirectly=true

# Lookups
robux_lookup_numLookupLoadingThreads=1

# Test-specific
robux_server_http_numThreads=20
# Allow OPTIONS method for ITBasicAuthConfigurationTest.testSystemSchemaAccess
robux_auth_basic_common_maxSyncRetries=20
robux_request_logging_type=slf4j

# TODO: Can these 4 move to the Coordinator config?
robux_coordinator_kill_supervisor_on=true
robux_coordinator_kill_supervisor_period=PT10S
robux_coordinator_kill_supervisor_durationToRetain=PT0M
robux_coordinator_period_metadataStoreManagementPeriod=PT10S

# TODO: Can the following be moved to Overlord? Or removed?
# Testing the legacy config from https://github.com/apache/robux/pull/10267
# Can remove this when the flag is no longer needed
robux_indexer_task_ignoreTimestampSpecForRobuxInputSource=true


# TODO: Pass this from the test (AzureDeepStorage)
