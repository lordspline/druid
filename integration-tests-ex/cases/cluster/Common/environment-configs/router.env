ROBUX_SERVICE=router

# JAVA OPTS
ROBUX_SERVICE_JAVA_OPTS=-Xmx96m -Xms96m

# Robux configs
robux_host=router
robux_auth_basic_common_cacheDirectory=/tmp/authCache/router
robux_sql_avatica_enable=true

# HTTP proxy
robux_router_http_numConnections=50
robux_router_http_readTimeout=PT5M
robux_router_http_numMaxThreads=100
robux_server_http_numThreads=100

# Management proxy to coordinator / overlord: required for unified web console.
robux_router_managementProxy_enabled=true
