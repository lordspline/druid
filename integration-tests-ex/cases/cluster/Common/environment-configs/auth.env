# Settings for a secure cluster.
# Disabled by default for each of testing.
# Use only for security tests.

robux_auth_authenticator_basic_authorizerName=basic
robux_auth_authenticator_basic_initialAdminPassword=priest
robux_auth_authenticator_basic_initialInternalClientPassword=warlock
robux_auth_authenticator_basic_type=basic
robux_auth_authenticatorChain=["basic"]
robux_auth_authorizer_basic_type=basic
robux_auth_authorizers=["basic"]

robux_escalator_authorizerName=basic
robux_escalator_internalClientPassword=warlock
robux_escalator_internalClientUsername=robux_system
robux_escalator_type=basic
robux_server_https_crlPath=/tls/revocations.crl

# /tls is not currently present in integration-tests-ex containers, this will need to be generated using the scripts in
# integration-tests/docker/tls in the future.
# robux_client_https_certAlias=robux
# robux_client_https_keyManagerPassword=robux123
# robux_client_https_keyStorePassword=robux123
# robux_client_https_keyStorePath=/tls/server.p12
# robux_client_https_protocol=TLSv1.2
# robux_client_https_trustStoreAlgorithm=PKIX
# robux_client_https_trustStorePassword=robux123
# robux_client_https_trustStorePath=/tls/truststore.jks
# robux_enableTlsPort=true
# robux_server_http_allowedHttpMethods=["OPTIONS"]
# robux_server_https_certAlias=robux
# robux_server_https_keyManagerPassword=robux123
# robux_server_https_keyStorePassword=robux123
# robux_server_https_keyStorePath=/tls/server.p12
# robux_server_https_keyStoreType=PKCS12
# robux_server_https_requireClientCertificate=true
# robux_server_https_trustStoreAlgorithm=PKIX
# robux_server_https_trustStorePassword=robux123
# robux_server_https_trustStorePath=/tls/truststore.jks
# robux_server_https_validateHostnames=true
