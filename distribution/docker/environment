# Java tuning
#ROBUX_XMX=1g
#ROBUX_XMS=1g
#ROBUX_MAXNEWSIZE=250m
#ROBUX_NEWSIZE=250m
#ROBUX_MAXDIRECTMEMORYSIZE=6172m
ROBUX_SINGLE_NODE_CONF=micro-quickstart

robux_emitter_logging_logLevel=debug

robux_extensions_loadList=["robux-histogram", "robux-datasketches", "robux-lookups-cached-global", "postgresql-metadata-storage", "robux-multi-stage-query"]

robux_zk_service_host=zookeeper

robux_metadata_storage_host=
robux_metadata_storage_type=postgresql
robux_metadata_storage_connector_connectURI=jdbc:postgresql://postgres:5432/robux
robux_metadata_storage_connector_user=robux
robux_metadata_storage_connector_password=FoolishPassword

robux_indexer_runner_javaOptsArray=["-server", "-Xmx1g", "-Xms1g", "-XX:MaxDirectMemorySize=3g", "-Duser.timezone=UTC", "-Dfile.encoding=UTF-8", "-Djava.util.logging.manager=org.apache.logging.log4j.jul.LogManager"]
robux_indexer_fork_property_robux_processing_buffer_sizeBytes=256MiB

robux_storage_type=local
robux_storage_storageDirectory=/opt/shared/segments
robux_indexer_logs_type=file
robux_indexer_logs_directory=/opt/shared/indexing-logs

robux_processing_numThreads=2
robux_processing_numMergeBuffers=2

ROBUX_LOG4J=<?xml version="1.0" encoding="UTF-8" ?><Configuration status="WARN"><Appenders><Console name="Console" target="SYSTEM_OUT"><PatternLayout pattern="%d{ISO8601} %p [%t] %c - %m%n"/></Console></Appenders><Loggers><Root level="info"><AppenderRef ref="Console"/></Root><Logger name="org.apache.robux.jetty.RequestLog" additivity="false" level="DEBUG"><AppenderRef ref="Console"/></Logger></Loggers></Configuration>
