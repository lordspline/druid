LANG=C.UTF-8
LANGUAGE=C.UTF-8
LC_ALL=C.UTF-8

# JAVA OPTS
COMMON_ROBUX_JAVA_OPTS=-Duser.timezone=UTC -Dfile.encoding=UTF-8 -Dlog4j.configurationFile=/shared/docker/lib/log4j2.xml -XX:+ExitOnOutOfMemoryError -XX:+HeapDumpOnOutOfMemoryError -XX:OnOutOfMemoryError='chmod 644 /shared/logs/*.hprof' -XX:HeapDumpPath=/shared/logs
ROBUX_DEP_BIN_DIR=/shared/docker/bin
ROBUX_DEP_LIB_DIR=/shared/hadoop_xml:/shared/docker/lib/*:/usr/local/robux/lib/mysql-connector-j.jar

# Robux configs
# If you are making a change in load list below, make the necessary changes in github actions too
robux_extensions_loadList=["mysql-metadata-storage","robux-basic-security","simple-client-sslcontext","robux-testing-tools","robux-lookups-cached-global","robux-histogram","robux-datasketches","robux-parquet-extensions","robux-avro-extensions","robux-protobuf-extensions","robux-orc-extensions","robux-kafka-indexing-service","robux-s3-extensions","robux-multi-stage-query"]
robux_startup_logging_logProperties=true
robux_extensions_directory=/shared/docker/extensions
robux_auth_authenticator_basic_authorizerName=basic
robux_auth_authenticator_basic_initialAdminPassword=priest
robux_auth_authenticator_basic_initialInternalClientPassword=warlock
robux_auth_authenticator_basic_type=basic
robux_auth_authenticatorChain=["basic"]
robux_auth_authorizer_basic_type=basic
robux_auth_authorizers=["basic"]
robux_auth_authorizeQueryContextParams=true
robux_client_https_certAlias=robux
robux_client_https_keyManagerPassword=robux123
robux_client_https_keyStorePassword=robux123
robux_client_https_keyStorePath=/tls/server.p12
robux_client_https_protocol=TLSv1.2
robux_client_https_trustStoreAlgorithm=PKIX
robux_client_https_trustStorePassword=robux123
robux_client_https_trustStorePath=/tls/truststore.jks
robux_enableTlsPort=true
robux_escalator_authorizerName=basic
robux_escalator_internalClientPassword=warlock
robux_escalator_internalClientUsername=robux_system
robux_escalator_type=basic
robux_lookup_numLookupLoadingThreads=1
robux_server_http_numThreads=20
# Allow OPTIONS method for ITBasicAuthConfigurationTest.testSystemSchemaAccess
robux_server_http_allowedHttpMethods=["OPTIONS"]
robux_server_https_certAlias=robux
robux_server_https_keyManagerPassword=robux123
robux_server_https_keyStorePassword=robux123
robux_server_https_keyStorePath=/tls/server.p12
robux_server_https_keyStoreType=PKCS12
robux_server_https_requireClientCertificate=true
robux_server_https_trustStoreAlgorithm=PKIX
robux_server_https_trustStorePassword=robux123
robux_server_https_trustStorePath=/tls/truststore.jks
robux_server_https_validateHostnames=true
robux_zk_service_host=robux-zookeeper-kafka
robux_auth_basic_common_maxSyncRetries=20
robux_indexer_logs_directory=/shared/tasklogs
robux_sql_enable=true
robux_extensions_hadoopDependenciesDir=/shared/hadoop-dependencies
robux_request_logging_type=slf4j
robux_coordinator_kill_supervisor_on=true
robux_coordinator_kill_supervisor_period=PT10S
robux_coordinator_kill_supervisor_durationToRetain=PT0M
robux_coordinator_period_metadataStoreManagementPeriod=PT10S
robux_sql_planner_authorizeSystemTablesDirectly=true
robux_audit_manager_type=log

# Testing the legacy config from https://github.com/apache/robux/pull/10267
# Can remove this when the flag is no longer needed
robux_indexer_task_ignoreTimestampSpecForRobuxInputSource=true

# Cluster testing
robux_unsafe_cluster_testing=true

# Dart
robux_msq_dart_enabled = true
