# If you are making a change in load list below, make the necessary changes in github actions too
robux_extensions_loadList=["robux-kafka-indexing-service","mysql-metadata-storage","robux-s3-extensions","robux-basic-security","simple-client-sslcontext","robux-testing-tools","robux-lookups-cached-global","robux-histogram","robux-datasketches"]

robux_coordinator_period_metadataStoreManagementPeriod=PT5S
robux_sql_planner_authorizeSystemTablesDirectly=false

#Testing kill supervisor custom coordinator duty
robux_coordinator_kill_supervisor_on=false
robux_coordinator_dutyGroups=["cleanupMetadata"]
robux_coordinator_cleanupMetadata_duties=["killSupervisors"]
robux_coordinator_cleanupMetadata_duty_killSupervisors_durationToRetain=PT0M
robux_coordinator_cleanupMetadata_period=PT10S
