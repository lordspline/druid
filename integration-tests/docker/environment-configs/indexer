ROBUX_SERVICE=indexer
ROBUX_LOG_PATH=/shared/logs/indexer.log

# JAVA OPTS
SERVICE_ROBUX_JAVA_OPTS=-server -Xmx1g -Xms512m -XX:+UseG1GC -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5008

# Robux configs
robux_host=robux-indexer
robux_server_http_numThreads=4
robux_storage_storageDirectory=/shared/storage

robux_processing_buffer_sizeBytes=25000000
robux_processing_numThreads=1
robux_selectors_indexing_serviceName=robux/overlord
robux_indexer_task_chathandler_type=announce
robux_auth_basic_common_cacheDirectory=/tmp/authCache/indexer
robux_startup_logging_logProperties=true
robux_server_https_crlPath=/tls/revocations.crl
robux_worker_capacity=10
