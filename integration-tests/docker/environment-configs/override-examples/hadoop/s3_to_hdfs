#
# Example of override config file to provide.
# Please replace <OVERRIDE_THIS> with your cloud configs/credentials
#
robux_s3_accessKey=<OVERRIDE_THIS>
robux_s3_secretKey=<OVERRIDE_THIS>

robux_storage_type=hdfs
robux_storage_storageDirectory=/robux/segments

AWS_REGION=<OVERRIDE_THIS>

robux_extensions_loadList=["robux-s3-extensions","robux-hdfs-storage"]

