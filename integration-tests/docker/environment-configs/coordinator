ROBUX_SERVICE=coordinator
ROBUX_LOG_PATH=/shared/logs/coordinator.log

# JAVA OPTS
SERVICE_ROBUX_JAVA_OPTS=-server -Xmx128m -Xms64m -XX:+UseG1GC -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5006

# Robux configs
robux_host=robux-coordinator
robux_metadata_storage_type=mysql
robux_metadata_storage_connector_connectURI=jdbc:mysql://robux-metadata-storage/robux
robux_metadata_storage_connector_user=robux
robux_metadata_storage_connector_password=diurd
robux_coordinator_startDelay=PT5S
robux_manager_lookups_hostUpdateTimeout=PT30S
robux_manager_lookups_period=10000
robux_manager_lookups_threadPoolSize=2
robux_manager_config_pollDuration=PT10S
robux_manager_rules_pollDuration=PT10S
robux_manager_segments_pollDuration=PT2S
robux_manager_segments_useIncrementalCache=always
robux_auth_basic_common_cacheDirectory=/tmp/authCache/coordinator
robux_auth_unsecuredPaths=["/robux/coordinator/v1/loadqueue"]
robux_server_https_crlPath=/tls/revocations.crl
robux_coordinator_period_indexingPeriod=PT180000S
# 2x indexing period so that kill period is valid
robux_coordinator_kill_period=PT360000S
robux_coordinator_period=PT1S
