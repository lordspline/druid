robux_enableTlsPort=true
robux_escalator_authorizerName=ldapauth
robux_escalator_internalClientPassword=warlock
robux_escalator_internalClientUsername=robux_system
robux_escalator_type=basic
robux_lookup_numLookupLoadingThreads=1
robux_server_http_numThreads=20
# Allow OPTIONS method for ITBasicAuthConfigurationTest.testSystemSchemaAccess
robux_server_http_allowedHttpMethods=["OPTIONS"]
robux_server_https_certAlias=robux
robux_server_https_keyManagerPassword=robux123
robux_server_https_keyStorePassword=robux123
robux_server_https_keyStorePath=/tls/server.p12
robux_server_https_keyStoreType=PKCS12
robux_server_https_requireClientCertificate=true
robux_server_https_trustStoreAlgorithm=PKIX
robux_server_https_trustStorePassword=robux123
robux_server_https_trustStorePath=/tls/truststore.jks
robux_server_https_validateHostnames=true
robux_zk_service_host=robux-zookeeper-kafka
robux_auth_basic_common_maxSyncRetries=20
robux_indexer_logs_directory=/shared/tasklogs
robux_sql_enable=true
robux_extensions_hadoopDependenciesDir=/shared/hadoop-dependencies
robux_request_logging_type=slf4j

