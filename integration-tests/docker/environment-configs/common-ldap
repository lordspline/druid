LANG=C.UTF-8
LANGUAGE=C.UTF-8
LC_ALL=C.UTF-8
AWS_REGION=us-east-1

# JAVA OPTS
COMMON_ROBUX_JAVA_OPTS=-Duser.timezone=UTC -Dfile.encoding=UTF-8 -Dlog4j.configurationFile=/shared/docker/lib/log4j2.xml -XX:+ExitOnOutOfMemoryError -XX:+HeapDumpOnOutOfMemoryError -XX:OnOutOfMemoryError='chmod 644 /shared/logs/*.hprof'  -XX:HeapDumpPath=/shared/logs
ROBUX_DEP_BIN_DIR=/shared/docker/bin
ROBUX_DEP_LIB_DIR=/shared/hadoop_xml:/shared/docker/lib/*:/usr/local/robux/lib/mysql-connector-j.jar

# Robux configs
# If you are making a change in load list below, make the necessary changes in github actions too
robux_extensions_loadList=["mysql-metadata-storage","robux-s3-extensions","robux-basic-security","simple-client-sslcontext","robux-testing-tools","robux-lookups-cached-global","robux-histogram","robux-datasketches","robux-multi-stage-query"]
robux_extensions_directory=/shared/docker/extensions
robux_auth_authenticator_ldap_authorizerName=ldapauth
robux_auth_authenticator_ldap_initialAdminPassword=priest
robux_auth_authenticator_ldap_initialInternalClientPassword=warlock
robux_auth_authenticator_ldap_type=basic
robux_auth_authenticator_ldap_credentialsValidator_type=ldap
robux_auth_authenticator_ldap_credentialsValidator_url=ldap://robux-openldap:389
robux_auth_authenticator_ldap_credentialsValidator_bindUser=cn=admin,dc=example,dc=org
robux_auth_authenticator_ldap_credentialsValidator_bindPassword=admin
robux_auth_authenticator_ldap_credentialsValidator_baseDn=ou=Users,dc=example,dc=org
robux_auth_authenticator_ldap_credentialsValidator_userSearch=(&(uid=%s)(objectClass=inetOrgPerson))
robux_auth_authenticator_ldap_credentialsValidator_userAttribute=uid
robux_auth_authenticatorChain=["ldap"]
robux_auth_authorizer_ldapauth_type=basic
robux_auth_authorizer_ldapauth_initialAdminUser=admin
robux_auth_authorizer_ldapauth_initialAdminRole=admin
robux_auth_authorizer_ldapauth_roleProvider_type=ldap
robux_auth_authorizers=["ldapauth"]
robux_auth_authorizeQueryContextParams=true
robux_client_https_certAlias=robux
robux_client_https_keyManagerPassword=robux123
robux_client_https_keyStorePassword=robux123
robux_client_https_keyStorePath=/tls/server.p12
