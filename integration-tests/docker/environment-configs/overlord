ROBUX_SERVICE=overlord
ROBUX_LOG_PATH=/shared/logs/overlord.log

# JAVA OPTS
SERVICE_ROBUX_JAVA_OPTS=-server -Xmx128m -Xms64m -XX:+UseG1GC -agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5009

# Robux configs
robux_host=robux-overlord
robux_metadata_storage_type=mysql
robux_metadata_storage_connector_connectURI=jdbc:mysql://robux-metadata-storage/robux
robux_metadata_storage_connector_user=robux
robux_metadata_storage_connector_password=diurd
robux_indexer_storage_type=metadata
robux_indexer_runner_type=remote
robux_auth_basic_common_cacheDirectory=/tmp/authCache/overlord
robux_server_https_crlPath=/tls/revocations.crl
robux_manager_segments_pollDuration=PT2S
robux_manager_segments_useIncrementalCache=always
